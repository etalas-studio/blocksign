# BlockSign Backend Configuration

# Server Settings
HOST=127.0.0.1
PORT=3000

# Storage Settings
UPLOAD_DIR=/tmp/blocksign_uploads
MAX_FILE_SIZE_MB=10
FILE_RETENTION_HOURS=24

# Database Settings
DATABASE_URL=sqlite:///data/blocksign.db
DATABASE_BACKUP_DIR=/data/backups
DATABASE_MAX_CONNECTIONS=10

# Blockchain Settings
# Polygon Amoy Testnet RPC URL (get from https://infura.io or https://alchemy.com)
RPC_URL=https://polygon-amoy.blockpi.network/v1/rpc/public

# Deployed BlockSign Smart Contract Address on Polygon Amoy
CONTRACT_ADDRESS=<your-deployed-contract-address>

# Chain ID (80002 = Polygon Amoy Testnet)
CHAIN_ID=80002

# Logging
RUST_LOG=info
